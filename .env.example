# フィードバック送信（/api/feedback）用の環境変数サンプル。
# 実値はリポジトリに置かず、ローカルは .env.local、本番は Vercel の
# Project Settings → Environment Variables に設定すること。

# 必須: Resend の API キー（https://resend.com で取得）。
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# 任意: 受信先メールアドレス（未設定なら kce.hello@gmail.com）。
FEEDBACK_TO_EMAIL=kce.hello@gmail.com

# 任意: 差出人（未設定なら "まなびドリル <onboarding@resend.dev>"）。
# 独自ドメインを Resend で認証した場合は、そのドメインのアドレスに変更する。
FEEDBACK_FROM_EMAIL=まなびドリル <onboarding@resend.dev>
